generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          String   @default("student")

  status       String   @default("active")
  department   String?
  phone        String?

  rfidCardId    String?  @unique

  sessions Session[]
  transactions  Transaction[]
  borrowedEquipment Equipment[] @relation("EquipmentBorrower")
  createdAt     DateTime @default(now())
}

model Equipment {
  id          String   @id @default(uuid())

  name        String
  category    String?
  location    String?
  description String?

  rfidTag     String? @unique

  status      String @default("available")

  assignedToId String?
  assignedTo   User? @relation("EquipmentBorrower", fields: [assignedToId], references: [id])
  assignedAt   DateTime?
  dueDate DateTime?

  transactions Transaction[]

  createdAt DateTime @default(now())
}

model Transaction {
  id          String   @id @default(uuid())

  userId      String
  equipmentId String

  action      String

  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  session Session? @relation(fields:[sessionId], references:[id])

  sessionId String?
}

model Session {
  id         String   @id @default(uuid())

  userId     String

  active     Boolean  @default(true)

  startTime  DateTime @default(now())

  endTime    DateTime?

  user       User @relation(fields:[userId], references:[id])

  transactions Transaction[]
}